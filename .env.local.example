# Sentry — get these from sentry.io → Settings → Projects → your project
NEXT_PUBLIC_SENTRY_DSN=   # Client-side DSN (public, safe to expose)
SENTRY_DSN=               # Server/edge DSN (keep secret)
SENTRY_ORG=               # Your Sentry org slug
SENTRY_PROJECT=           # Your Sentry project slug
SENTRY_AUTH_TOKEN=        # From sentry.io/settings/auth-tokens/ — needs project:releases + org:read

# PostHog — get these from posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
